#!/usr/bin/env bash
# ═══ Event-Driven Eww Bar Manager ═══
# Runs as a single long-lived reconciler for bar windows:
#   - ensures only one manager instance is active
#   - starts a fresh eww daemon for the current session
#   - waits for Hyprland monitor topology to settle
#   - rebuilds only the managed bar windows when topology changes

set -u

MAX_BARS=3
LOCK_DIR="${XDG_RUNTIME_DIR:-/tmp}/eww-manage-bars.lock"
SOCKET="$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock"
LAST_APPLIED_SIGNATURE=""

bar_name() {
  printf 'bar%s\n' "$1"
}

close_managed_bars() {
  local i
  for i in $(seq 0 $((MAX_BARS - 1))); do
    eww close "$(bar_name "$i")" 2>/dev/null || true
  done
}

monitor_state() {
  hyprctl monitors -j 2>/dev/null |
    jq -r '[length, (sort_by(.id) | map("\(.id):\(.name)") | join("|"))] | @tsv' 2>/dev/null
}

wait_for_stable_monitors() {
  local state=""
  local previous=""
  local stable_reads=0
  local _

  for _ in $(seq 1 30); do
    state=$(monitor_state)
    if [ -n "$state" ] && [ "$state" = "$previous" ]; then
      stable_reads=$((stable_reads + 1))
      if [ "$stable_reads" -ge 2 ]; then
        printf '%s\n' "$state"
        return 0
      fi
    else
      stable_reads=0
      previous="$state"
    fi

    sleep 0.2
  done

  if [ -n "$previous" ]; then
    printf '%s\n' "$previous"
  fi
}

reconcile_bars() {
  local state count signature i

  state=$(wait_for_stable_monitors)
  [ -n "$state" ] || return 0

  IFS=$'\t' read -r count signature <<< "$state"
  [ -n "$count" ] || return 0

  if [ "$count" -gt "$MAX_BARS" ]; then
    count="$MAX_BARS"
  fi

  if [ "$signature" = "$LAST_APPLIED_SIGNATURE" ]; then
    return 0
  fi

  close_managed_bars
  sleep 0.1

  if [ "$count" -gt 0 ]; then
    for i in $(seq 0 $((count - 1))); do
      eww open "$(bar_name "$i")"
    done
  fi

  LAST_APPLIED_SIGNATURE="$signature"
}

acquire_lock() {
  if mkdir "$LOCK_DIR" 2>/dev/null; then
    printf '%s\n' "$$" > "$LOCK_DIR/pid"
    return 0
  fi

  if [ -f "$LOCK_DIR/pid" ]; then
    local existing_pid
    existing_pid=$(cat "$LOCK_DIR/pid" 2>/dev/null || true)
    if [ -n "$existing_pid" ] && kill -0 "$existing_pid" 2>/dev/null; then
      exit 0
    fi
  fi

  rm -rf "$LOCK_DIR"
  mkdir "$LOCK_DIR" 2>/dev/null || exit 0
  printf '%s\n' "$$" > "$LOCK_DIR/pid"
}

cleanup() {
  eww kill 2>/dev/null || true
  rm -rf "$LOCK_DIR"
}

trap cleanup EXIT
trap 'exit 0' TERM INT HUP

kill_existing_daemon() {
  eww kill 2>/dev/null || true

  local _
  for _ in $(seq 1 30); do
    pgrep -x eww >/dev/null 2>&1 || return 0
    sleep 0.1
  done

  pkill -9 -x eww 2>/dev/null || true
}

start_daemon() {
  local _

  eww daemon
  for _ in $(seq 1 50); do
    if eww list >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.1
  done

  return 1
}

acquire_lock
kill_existing_daemon
start_daemon
reconcile_bars

# Hyprland socket2 emits monitoradded>>NAME / monitorremoved>>NAME.
# Re-run reconciliation whenever monitor topology changes.
while true; do
  socat -U - UNIX-CONNECT:"$SOCKET" 2>/dev/null |
    while IFS= read -r event; do
      case "$event" in
        monitoradded*|monitorremoved*)
          reconcile_bars
          ;;
      esac
    done

  sleep 1
done
