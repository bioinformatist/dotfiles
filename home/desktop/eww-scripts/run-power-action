#!/usr/bin/env bash
# ═══ Eww Power Action Runner ═══
# Closes the per-monitor power popup, then executes the requested action.

set -eu

ACTION="${1:?Usage: run-power-action <logout|poweroff|reboot> <monitor_id>}"
MON="${2:?Usage: run-power-action <logout|poweroff|reboot> <monitor_id>}"

eww close "power-popup-${MON}" "power-closer-${MON}" 2>/dev/null || true

case "$ACTION" in
  logout)
    exec uwsm stop
    ;;
  poweroff|reboot)
    exec systemctl --user start --no-block "dotfiles-power-action@${ACTION}.service"
    ;;
  *)
    echo "Unknown power action: $ACTION" >&2
    exit 1
    ;;
esac
