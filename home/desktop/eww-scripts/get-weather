#!/usr/bin/env bash
# ═══ Weather Data (yr.no MET Norway API) ═══
# Called by defpoll every 30 minutes.
# Auto-detects location via IP on first run and caches.
# Requires: curl, jq

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/eww"
LOCATION_CACHE="$CACHE_DIR/weather_location.json"
WEATHER_CACHE="$CACHE_DIR/weather_data.json"

mkdir -p "$CACHE_DIR"

# ─── Get location (cached) ───────────────────────────────────
if [ ! -f "$LOCATION_CACHE" ]; then
  curl -sf "http://ip-api.com/json" \
    | jq '{lat: .lat, lon: .lon, city: .city}' \
    > "$LOCATION_CACHE" 2>/dev/null
fi

if [ ! -f "$LOCATION_CACHE" ]; then
  echo '{"temp":"N/A","icon":"?","city":"Unknown","symbol":""}'
  exit 0
fi

LAT=$(jq -r '.lat' "$LOCATION_CACHE")
LON=$(jq -r '.lon' "$LOCATION_CACHE")
CITY=$(jq -r '.city' "$LOCATION_CACHE")

# ─── Fetch weather ────────────────────────────────────────────
WEATHER=$(curl -sf \
  -H "User-Agent: eww-weather/1.0 github.com/bioinformatist/dotfiles" \
  "https://api.met.no/weatherapi/locationforecast/2.0/compact?lat=$LAT&lon=$LON")

if [ $? -ne 0 ] || [ -z "$WEATHER" ]; then
  # Fallback to cached data
  if [ -f "$WEATHER_CACHE" ]; then
    cat "$WEATHER_CACHE"
  else
    echo '{"temp":"N/A","icon":"?","city":"Unknown","symbol":""}'
  fi
  exit 0
fi

# ─── Parse weather data ──────────────────────────────────────
TEMP=$(echo "$WEATHER" | jq -r '
  .properties.timeseries[0].data.instant.details.air_temperature | round')

SYMBOL=$(echo "$WEATHER" | jq -r '
  .properties.timeseries[0].data.next_1_hours.summary.symbol_code //
  .properties.timeseries[0].data.next_6_hours.summary.symbol_code //
  "unknown"')

# ─── Map yr.no symbol code to icon ───────────────────────────
case "$SYMBOL" in
  clearsky_day)                    ICON="☀" ;;
  clearsky_night)                  ICON="☾" ;;
  clearsky_polartwilight)          ICON="☀" ;;
  fair_day|partlycloudy_day)       ICON="⛅" ;;
  fair_night|partlycloudy_night)   ICON="☁" ;;
  cloudy)                          ICON="☁" ;;
  *rain*)                          ICON="☂" ;;
  *snow*|*sleet*)                  ICON="❄" ;;
  fog)                             ICON="≋" ;;
  *thunder*)                       ICON="⚡" ;;
  *)                               ICON="☁" ;;
esac

# ─── Output JSON ─────────────────────────────────────────────
RESULT=$(jq -cn \
  --arg temp "$TEMP" \
  --arg icon "$ICON" \
  --arg city "$CITY" \
  --arg symbol "$SYMBOL" \
  '{temp: $temp, icon: $icon, city: $city, symbol: $symbol}')

echo "$RESULT" | tee "$WEATHER_CACHE"
